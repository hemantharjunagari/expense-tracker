<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/medium_spent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="@font/space_mono_bold" />

            <TextView
                android:id="@+id/medium_budget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="of ₹0"
                android:textColor="#606060"
                android:textSize="11sp"
                android:fontFamily="@font/space_grotesk_regular" />

        </LinearLayout>

        <TextView
            android:id="@+id/medium_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="#AAAAAA"
            android:textSize="20sp"
            android:fontFamily="@font/space_mono_regular"
            android:gravity="end" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/medium_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginTop="10dp"
        android:progress="0"
        android:max="100"
        android:progressTint="#FF3E3E"
        android:progressBackgroundTint="#1A1A1A" />

    <!-- Top categories -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/medium_cat1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🍽️ Food  ₹0"
            android:textColor="#808080"
            android:textSize="11sp"
            android:paddingBottom="4dp"
            android:fontFamily="@font/space_grotesk_regular" />

        <TextView
            android:id="@+id/medium_cat2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛒 Groceries  ₹0"
            android:textColor="#808080"
            android:textSize="11sp"
            android:paddingBottom="4dp"
            android:fontFamily="@font/space_grotesk_regular" />

        <TextView
            android:id="@+id/medium_cat3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚗 Transport  ₹0"
            android:textColor="#808080"
            android:textSize="11sp"
            android:fontFamily="@font/space_grotesk_regular" />

    </LinearLayout>

</LinearLayout>
